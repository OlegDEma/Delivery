generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  super_admin
  admin
  warehouse_worker
  driver_courier
  client
}

enum Country {
  UA
  NL
  AT
  DE
}

enum ClientType {
  individual
  organization
}

enum DeliveryMethod {
  address
  np_warehouse
  np_poshtamat
}

enum Direction {
  eu_to_ua
  ua_to_eu
}

enum ShipmentType {
  parcels_cargo
  documents
  tires_wheels
}

enum PaymentMethod {
  cash
  cashless
}

enum Payer {
  sender
  receiver
}

enum ParcelStatus {
  draft
  accepted_for_transport_to_ua
  in_transit_to_ua
  at_lviv_warehouse
  at_nova_poshta
  delivered_ua
  accepted_for_transport_to_eu
  in_transit_to_eu
  at_eu_warehouse
  delivered_eu
  not_received
  refused
  returned
}

enum TripStatus {
  planned
  in_progress
  completed
  cancelled
}

enum RouteTaskType {
  pickup
  delivery
  passenger
}

enum RouteTaskStatus {
  pending
  address_confirmed
  in_navigator
  completed
  not_completed
  rescheduled
}

enum CashPaymentType {
  income
  expense
  refund
}

enum WeightType {
  actual
  volumetric
  average
}

enum CreatedSource {
  worker
  client_web
  client_telegram
}

enum WarehouseAction {
  received
  dispatched
  scanned
  packaged
}

// ============================================================
// TABLES
// ============================================================

model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String   @map("full_name")
  phone     String?
  role      UserRole @default(client)
  avatarUrl String?  @map("avatar_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  createdClients       Client[]              @relation("ClientCreatedBy")
  assignedParcels      Parcel[]              @relation("ParcelAssignedCourier")
  createdParcels       Parcel[]              @relation("ParcelCreatedBy")
  assignedTrips        Trip[]                @relation("TripAssignedCourier")
  secondCourierTrips   Trip[]                @relation("TripSecondCourier")
  createdTrips         Trip[]                @relation("TripCreatedBy")
  assignedJourneys     Journey[]             @relation("JourneyAssignedCourier")
  secondCourierJourneys Journey[]            @relation("JourneySecondCourier")
  createdJourneys      Journey[]             @relation("JourneyCreatedBy")
  assignedRouteTasks   RouteTask[]           @relation("RouteTaskAssignedCourier")
  cashReceived         CashRegister[]        @relation("CashReceivedBy")
  cashConfirmed        CashRegister[]        @relation("CashConfirmedBy")
  statusChanges        ParcelStatusHistory[]
  scannedPlaces        ParcelPlace[]         @relation("PlaceScannedBy")
  warehouseActions     WarehouseInventory[]
  pricingUpdates       PricingConfig[]       @relation("PricingUpdatedBy")
  createdClaims        Claim[]               @relation("ClaimCreatedBy")

  @@index([role])
  @@index([phone])
  @@map("profiles")
}

model Client {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone            String     @unique
  phoneNormalized  String     @map("phone_normalized")
  firstName        String     @map("first_name")
  lastName         String     @map("last_name")
  middleName       String?    @map("middle_name")
  email            String?
  clientType       ClientType @default(individual) @map("client_type")
  organizationName String?    @map("organization_name")
  country          Country?
  notes            String?
  createdById      String?    @map("created_by") @db.Uuid
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?  @map("deleted_at") @db.Timestamptz

  // Relations
  createdBy        Profile?         @relation("ClientCreatedBy", fields: [createdById], references: [id])
  addresses        ClientAddress[]
  sentParcels      Parcel[]         @relation("ParcelSender")
  receivedParcels  Parcel[]         @relation("ParcelReceiver")
  routeTasks       RouteTask[]
  claims           Claim[]

  @@index([phoneNormalized])
  @@index([lastName, firstName])
  @@map("clients")
}

model ClientAddress {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId        String         @map("client_id") @db.Uuid
  country         Country
  city            String
  street          String?
  building        String?
  apartment       String?
  postalCode      String?        @map("postal_code")
  landmark        String?
  npWarehouseNum  String?        @map("np_warehouse_num")
  npPoshtamatNum  String?        @map("np_poshtamat_num")
  deliveryMethod  DeliveryMethod @default(address) @map("delivery_method")
  usageCount      Int            @default(0) @map("usage_count")
  isDefault       Boolean        @default(false) @map("is_default")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  senderParcels   Parcel[]       @relation("ParcelSenderAddress")
  receiverParcels Parcel[]       @relation("ParcelReceiverAddress")
  routeTasks      RouteTask[]

  @@index([clientId])
  @@index([clientId, usageCount(sort: Desc)])
  @@map("client_addresses")
}

model Journey {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  country            Country
  departureDate      DateTime   @map("departure_date") @db.Date   // Дата виїзду з України (UA→EU)
  euArrivalDate      DateTime?  @map("eu_arrival_date") @db.Date  // Дата приїзду в країну
  euReturnDate       DateTime?  @map("eu_return_date") @db.Date   // Дата виїзду з країни (EU→UA)
  endDate            DateTime?  @map("end_date") @db.Date         // Дата приїзду в UA
  status             TripStatus @default(planned)
  assignedCourierId  String?    @map("assigned_courier_id") @db.Uuid
  secondCourierId    String?    @map("second_courier_id") @db.Uuid
  vehicleInfo        String?    @map("vehicle_info")
  notes              String?
  createdById        String?    @map("created_by") @db.Uuid
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  assignedCourier Profile? @relation("JourneyAssignedCourier", fields: [assignedCourierId], references: [id])
  secondCourier   Profile? @relation("JourneySecondCourier", fields: [secondCourierId], references: [id])
  createdBy       Profile? @relation("JourneyCreatedBy", fields: [createdById], references: [id])
  trips           Trip[]

  @@index([departureDate])
  @@index([status])
  @@map("journeys")
}

model Trip {
  id                       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  direction                Direction
  country                  Country
  departureDate            DateTime   @map("departure_date") @db.Date
  arrivalDate              DateTime?  @map("arrival_date") @db.Date
  status                   TripStatus @default(planned)
  journeyId                String?    @map("journey_id") @db.Uuid
  assignedCourierId        String?    @map("assigned_courier_id") @db.Uuid
  secondCourierId          String?    @map("second_courier_id") @db.Uuid
  vehicleInfo              String?    @map("vehicle_info")
  maxWeight                Decimal?   @map("max_weight") @db.Decimal(8, 2)
  notes                    String?
  shortNumberCounterNl     Int        @default(0) @map("short_number_counter_nl")
  shortNumberCounterVienna Int        @default(0) @map("short_number_counter_vienna")
  shortNumberCounterLinz   Int        @default(0) @map("short_number_counter_linz")
  shortNumberCounterGeo    Int        @default(0) @map("short_number_counter_geo")
  shortNumberCounterEuUa   Int        @default(0) @map("short_number_counter_eu_ua")
  createdById              String?    @map("created_by") @db.Uuid
  createdAt                DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  assignedCourier  Profile?    @relation("TripAssignedCourier", fields: [assignedCourierId], references: [id])
  secondCourier    Profile?    @relation("TripSecondCourier", fields: [secondCourierId], references: [id])
  createdBy        Profile?    @relation("TripCreatedBy", fields: [createdById], references: [id])
  journey          Journey?    @relation(fields: [journeyId], references: [id])
  parcels          Parcel[]
  routeTasks       RouteTask[]

  @@index([departureDate])
  @@index([assignedCourierId])
  @@index([status])
  @@map("trips")
}

model Parcel {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itn                   String        @unique
  internalNumber        String        @map("internal_number")
  sequentialNumber      Int           @map("sequential_number")
  shortNumber           Int?          @map("short_number")
  direction             Direction
  senderId              String        @map("sender_id") @db.Uuid
  senderAddressId       String?       @map("sender_address_id") @db.Uuid
  receiverId            String        @map("receiver_id") @db.Uuid
  receiverAddressId     String?       @map("receiver_address_id") @db.Uuid
  tripId                String?       @map("trip_id") @db.Uuid
  shipmentType          ShipmentType  @default(parcels_cargo) @map("shipment_type")
  description           String?
  declaredValue         Decimal?      @map("declared_value") @db.Decimal(10, 2)
  declaredValueCurrency String        @default("EUR") @map("declared_value_currency")
  totalWeight           Decimal?      @map("total_weight") @db.Decimal(8, 3)
  totalVolumetricWeight Decimal?      @map("total_volumetric_weight") @db.Decimal(8, 3)
  totalPlacesCount      Int           @default(1) @map("total_places_count")
  payer                 Payer         @default(sender)
  paymentMethod         PaymentMethod @default(cash) @map("payment_method")
  paymentInUkraine      Boolean       @default(false) @map("payment_in_ukraine")
  needsPackaging        Boolean       @default(false) @map("needs_packaging")
  deliveryCost          Decimal?      @map("delivery_cost") @db.Decimal(10, 2)
  packagingCost         Decimal?      @default(0) @map("packaging_cost") @db.Decimal(10, 2)
  insuranceCost         Decimal?      @default(0) @map("insurance_cost") @db.Decimal(10, 2)
  addressDeliveryCost   Decimal?      @default(0) @map("address_delivery_cost") @db.Decimal(10, 2)
  totalCost             Decimal?      @map("total_cost") @db.Decimal(10, 2)
  costCurrency          String        @default("EUR") @map("cost_currency")
  npTtn                 String?       @map("np_ttn")
  npTrackingStatus      String?       @map("np_tracking_status")
  status                ParcelStatus  @default(draft)
  createdSource         CreatedSource @default(worker) @map("created_source")
  createdById           String?       @map("created_by") @db.Uuid
  assignedCourierId     String?       @map("assigned_courier_id") @db.Uuid
  estimatedDeliveryStart DateTime?    @map("estimated_delivery_start") @db.Timestamptz
  estimatedDeliveryEnd   DateTime?    @map("estimated_delivery_end") @db.Timestamptz
  isPaid                Boolean       @default(false) @map("is_paid")
  paidAt                DateTime?     @map("paid_at") @db.Timestamptz
  photos                String[]      @default([])
  // Route task status (for daily route sheet)
  routeTaskStatus       String?       @map("route_task_status") // pending/address_confirmed/in_navigator/completed/not_completed/rescheduled
  routeTaskFailReason   String?       @map("route_task_fail_reason")
  routeTaskReschedDate  DateTime?     @map("route_task_reschedule_date") @db.Date
  // Soft delete
  deletedAt             DateTime?     @map("deleted_at") @db.Timestamptz
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  sender            Client              @relation("ParcelSender", fields: [senderId], references: [id])
  senderAddress     ClientAddress?      @relation("ParcelSenderAddress", fields: [senderAddressId], references: [id])
  receiver          Client              @relation("ParcelReceiver", fields: [receiverId], references: [id])
  receiverAddress   ClientAddress?      @relation("ParcelReceiverAddress", fields: [receiverAddressId], references: [id])
  trip              Trip?               @relation(fields: [tripId], references: [id])
  createdBy         Profile?            @relation("ParcelCreatedBy", fields: [createdById], references: [id])
  assignedCourier   Profile?            @relation("ParcelAssignedCourier", fields: [assignedCourierId], references: [id])
  places            ParcelPlace[]
  statusHistory     ParcelStatusHistory[]
  cashEntries       CashRegister[]
  routeTasks        RouteTask[]
  warehouseActions  WarehouseInventory[]
  npSyncLogs        NpSyncLog[]
  claims            Claim[]

  @@index([itn])
  @@index([npTtn])
  @@index([senderId])
  @@index([receiverId])
  @@index([tripId])
  @@index([status])
  @@index([assignedCourierId])
  @@index([createdAt])
  @@index([sequentialNumber])
  @@index([tripId, shortNumber])
  @@map("parcels")
}

model ParcelPlace {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parcelId         String    @map("parcel_id") @db.Uuid
  placeNumber      Int       @map("place_number")
  weight           Decimal?  @db.Decimal(8, 3)
  length           Decimal?  @db.Decimal(8, 2)
  width            Decimal?  @db.Decimal(8, 2)
  height           Decimal?  @db.Decimal(8, 2)
  volume           Decimal?  @db.Decimal(10, 4)
  volumetricWeight Decimal?  @map("volumetric_weight") @db.Decimal(8, 3)
  needsPackaging   Boolean   @default(false) @map("needs_packaging")
  packagingDone    Boolean   @default(false) @map("packaging_done")
  itnPlace         String?   @unique @map("itn_place")
  barcodeData      String?   @map("barcode_data")
  scannedAtWarehouse DateTime? @map("scanned_at_warehouse") @db.Timestamptz
  scannedById      String?   @map("scanned_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  parcel    Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  scannedBy Profile? @relation("PlaceScannedBy", fields: [scannedById], references: [id])

  @@unique([parcelId, placeNumber])
  @@index([parcelId])
  @@map("parcel_places")
}

model ParcelStatusHistory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parcelId   String   @map("parcel_id") @db.Uuid
  status     ParcelStatus
  changedById String? @map("changed_by") @db.Uuid
  changedAt  DateTime @default(now()) @map("changed_at") @db.Timestamptz
  notes      String?
  location   String?

  // Relations
  parcel    Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  changedBy Profile? @relation(fields: [changedById], references: [id])

  @@index([parcelId])
  @@index([changedAt])
  @@map("parcel_status_history")
}

model PricingConfig {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  country              Country
  direction            Direction
  pricePerKg           Decimal     @map("price_per_kg") @db.Decimal(10, 2)
  weightType           WeightType  @default(actual) @map("weight_type")
  insuranceThreshold   Decimal     @default(25.00) @map("insurance_threshold") @db.Decimal(10, 2)
  insuranceRate        Decimal     @default(0.01) @map("insurance_rate") @db.Decimal(5, 4)
  insuranceEnabled     Boolean     @default(true) @map("insurance_enabled")
  packagingEnabled     Boolean     @default(true) @map("packaging_enabled")
  packagingPrices      Json?       @map("packaging_prices")
  addressDeliveryPrice Decimal     @default(0) @map("address_delivery_price") @db.Decimal(10, 2)
  collectionDays       String[]    @map("collection_days")
  isActive             Boolean     @default(true) @map("is_active")
  updatedById          String?     @map("updated_by") @db.Uuid
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  updatedBy Profile? @relation("PricingUpdatedBy", fields: [updatedById], references: [id])

  @@map("pricing_config")
}

model CollectionPoint {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  country      Country
  city         String
  address      String
  postalCode   String?  @map("postal_code")
  contactPhone String?  @map("contact_phone")
  workingHours String?  @map("working_hours")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("collection_points")
}

model CashRegister {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parcelId      String?         @map("parcel_id") @db.Uuid
  amount        Decimal         @db.Decimal(10, 2)
  currency      String
  paymentMethod PaymentMethod   @map("payment_method")
  paymentType   CashPaymentType @default(income) @map("payment_type")
  description   String?
  receivedById  String          @map("received_by") @db.Uuid
  confirmed     Boolean         @default(false)
  confirmedById String?         @map("confirmed_by") @db.Uuid
  confirmedAt   DateTime?       @map("confirmed_at") @db.Timestamptz
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  parcel      Parcel?  @relation(fields: [parcelId], references: [id])
  receivedBy  Profile  @relation("CashReceivedBy", fields: [receivedById], references: [id])
  confirmedBy Profile? @relation("CashConfirmedBy", fields: [confirmedById], references: [id])

  @@index([parcelId])
  @@index([receivedById])
  @@index([createdAt])
  @@map("cash_register")
}

model RouteTask {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId                String          @map("trip_id") @db.Uuid
  parcelId              String?         @map("parcel_id") @db.Uuid
  taskType              RouteTaskType   @map("task_type")
  taskDate              DateTime        @map("task_date") @db.Date
  clientId              String?         @map("client_id") @db.Uuid
  addressId             String?         @map("address_id") @db.Uuid
  addressText           String?         @map("address_text")
  postalCode            String?         @map("postal_code")
  assignedCourierId     String?         @map("assigned_courier_id") @db.Uuid
  status                RouteTaskStatus @default(pending)
  rescheduleDate        DateTime?       @map("reschedule_date") @db.Date
  failureReason         String?         @map("failure_reason")
  sortOrder             Int?            @map("sort_order")
  estimatedArrivalStart DateTime?       @map("estimated_arrival_start") @db.Timestamptz
  estimatedArrivalEnd   DateTime?       @map("estimated_arrival_end") @db.Timestamptz
  notes                 String?
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  trip            Trip           @relation(fields: [tripId], references: [id])
  parcel          Parcel?        @relation(fields: [parcelId], references: [id])
  client          Client?        @relation(fields: [clientId], references: [id])
  address         ClientAddress? @relation(fields: [addressId], references: [id])
  assignedCourier Profile?       @relation("RouteTaskAssignedCourier", fields: [assignedCourierId], references: [id])

  @@index([tripId])
  @@index([taskDate])
  @@index([assignedCourierId])
  @@index([postalCode])
  @@map("route_tasks")
}

model WarehouseInventory {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parcelId   String          @map("parcel_id") @db.Uuid
  placeId    String?         @map("place_id") @db.Uuid
  action     WarehouseAction
  scannedById String?        @map("scanned_by") @db.Uuid
  scannedAt  DateTime        @default(now()) @map("scanned_at") @db.Timestamptz
  notes      String?

  // Relations
  parcel    Parcel   @relation(fields: [parcelId], references: [id])
  scannedBy Profile? @relation(fields: [scannedById], references: [id])

  @@index([parcelId])
  @@index([scannedAt])
  @@map("warehouse_inventory")
}

model NpSyncLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parcelId        String?  @map("parcel_id") @db.Uuid
  action          String
  requestPayload  Json?    @map("request_payload")
  responsePayload Json?    @map("response_payload")
  success         Boolean?
  errorMessage    String?  @map("error_message")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  parcel Parcel? @relation(fields: [parcelId], references: [id])

  @@index([parcelId])
  @@map("np_sync_log")
}

model YearlySequence {
  year       Int @id
  lastNumber Int @default(0) @map("last_number")

  @@map("yearly_sequence")
}

model DescriptionSuggestion {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text       String @unique
  usageCount Int    @default(1) @map("usage_count")

  @@map("description_suggestions")
}

enum ClaimStatus {
  open
  in_progress
  resolved
  rejected
}

model Claim {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parcelId    String      @map("parcel_id") @db.Uuid
  clientId    String?     @map("client_id") @db.Uuid
  type        String      // damage, lost, delay, other
  description String
  resolution  String?
  status      ClaimStatus @default(open)
  createdById String?     @map("created_by") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  parcel    Parcel   @relation(fields: [parcelId], references: [id])
  client    Client?  @relation(fields: [clientId], references: [id])
  createdBy Profile? @relation("ClaimCreatedBy", fields: [createdById], references: [id])

  @@index([parcelId])
  @@index([status])
  @@map("claims")
}
